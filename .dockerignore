node_modules
vendor

# Local build artifacts / symlinks — the frontend stage rebuilds public/build
# fresh and entrypoint.sh re-links storage + republishes Filament assets, so
# any stale copies from a non-Coolify (local) build context would just be
# dead weight, or in the storage symlink's case, break the build outright.
public/build
public/hot
public/storage
public/css/filament
public/js/filament

storage/app/*
!storage/app/.gitignore
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/testing/*
storage/framework/views/*
storage/logs/*
!storage/framework/**/.gitignore
!storage/logs/.gitignore

.env
.env.*
!.env.example

*.md
!README.md

tests
phpunit.xml
phpstan.neon
pint.json
.phpunit.cache
.phpunit.result.cache
.phpactor.json
.phpstan-cache
coverage

docker-compose*.yml
docs
