APP_NAME=DajPrezent
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Warsaw
APP_URL=http://localhost

APP_LOCALE=pl
APP_FALLBACK_LOCALE=pl
APP_FAKER_LOCALE=pl_PL

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dajprezent
DB_USERNAME=dajprezent
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=dajprezent

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Postmark (preferred) — fall back to MAIL_MAILER=log in dev.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@dajprezent.pl"
MAIL_FROM_NAME="${APP_NAME}"
POSTMARK_TOKEN=

# S3-compatible object storage (Wasabi / Backblaze / AWS) for gift images.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# PayU REST API (sandbox: https://secure.snd.payu.com).
PAYU_BASE_URL=https://secure.snd.payu.com
PAYU_POS_ID=
PAYU_CLIENT_ID=
PAYU_CLIENT_SECRET=
PAYU_MD5_KEY=
PAYU_NOTIFY_URL="${APP_URL}/webhooks/payu"

# Dane sprzedawcy — wystawca faktur (Sendormeco Holding sp. z o.o.).
# Dane KRS publicznie potwierdzone (KRS 0000906110, REGON 389194801).
SELLER_LEGAL_NAME="Sendormeco Holding sp. z o.o."
SELLER_BRAND="DajPrezent.pl"
SELLER_NIP=5252866457
SELLER_REGON=389194801
SELLER_KRS=0000906110
SELLER_STREET="ul. Złota 75A/7"
SELLER_POSTAL_CODE="00-819"
SELLER_CITY=Warszawa
SELLER_COUNTRY=PL
SELLER_EMAIL=kontakt@dajprezent.pl
SELLER_PHONE=
SELLER_BANK_ACCOUNT=
SELLER_SHARE_CAPITAL_PLN=5000
SELLER_REGISTRY_COURT="Sąd Rejonowy dla m.st. Warszawy w Warszawie, XII Wydział Gospodarczy KRS"

# KSeF (Krajowy System e-Faktur). Use 'test' endpoint until production-ready.
KSEF_ENV=test
KSEF_NIP=${SELLER_NIP}
KSEF_TOKEN=

# Cloudflare Turnstile for public forms (reservations, RSVP).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

VITE_APP_NAME="${APP_NAME}"
